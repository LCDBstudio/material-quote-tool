import os
import re
import requests
from dotenv import load_dotenv

load_dotenv()

SERPAPI_KEY=67a7a5c1606865714218efec57c3f6c8af58e1c85983a19c784c01fb3d8eb460

def infer_product_coverage(title):
    text = title.lower()

    # Drywall sizes
    if "4 ft. x 8 ft" in text or "4-ft x 8-ft" in text or "4 x 8" in text or "4x8" in text:
        return 32, "sf", "sheet"

    if "4 ft. x 10 ft" in text or "4-ft x 10-ft" in text or "4 x 10" in text or "4x10" in text:
        return 40, "sf", "sheet"

    # Paint pails
    if "18.9l" in text or "18.9 l" in text or "18.96l" in text or "18.96 l" in text:
        return 1900, "sf", "pail"

    if "3.66l" in text or "3.66 l" in text:
        return 400, "sf", "can"

    # Contractor bags
    pack_match = re.search(r"(\d+)[-\s]?pack", text)
    if "bag" in text and pack_match:
        return int(pack_match.group(1)), "qty", "box"

    return None, None, None


def search_google_shopping(query, location="Vancouver, British Columbia, Canada", max_results=10):
    if not SERPAPI_KEY:
        raise ValueError("Missing SERPAPI_KEY in .env file")

    params = {
        "engine": "google_shopping",
        "q": query,
        "location": location,
        "google_domain": "google.ca",
        "gl": "ca",
        "hl": "en",
        "api_key": SERPAPI_KEY,
    }

    response = requests.get("https://serpapi.com/search.json", params=params, timeout=30)
    response.raise_for_status()

    data = response.json()
    results = data.get("shopping_results", [])

    products = []

    for item in results[:max_results]:
        title = item.get("title", "")
        coverage_qty, coverage_unit, store_unit = infer_product_coverage(title)

        products.append({
            "Vendor": item.get("source"),
            "Product": title,
            "Price": item.get("extracted_price"),
            "Displayed Price": item.get("price"),
            "Product URL": item.get("product_link") or item.get("link"),
            "Coverage Qty": coverage_qty,
            "Coverage Unit": coverage_unit,
            "Store Unit": store_unit,
            "Thumbnail": item.get("thumbnail"),
        })

    return products